<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.kindle-display.usbnetwork-repair</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/libexec/kindle-display/kindle-usbnetwork-repair.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>300</integer>
  <key>ProcessType</key>
  <string>Background</string>
  <key>StandardOutPath</key>
  <string>/var/log/kindle-usbnetwork-repair.log</string>
  <key>StandardErrorPath</key>
  <string>/var/log/kindle-usbnetwork-repair.log</string>
</dict>
</plist>
